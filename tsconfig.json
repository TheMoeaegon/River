{
    "compilerOptions": {
        // "noEmit": true,
        "target": "esnext",
        "module": "nodenext",
        "outDir": "dist",
        "rootDir": ".",
        "rewriteRelativeImportExtensions": true,
        "erasableSyntaxOnly": true,
        "verbatimModuleSyntax": true,
        "allowImportingTsExtensions": true,
    },
    "exclude": ["node_modules", "dist"],
    "include": ["src/**/*", "index.ts"],
}
